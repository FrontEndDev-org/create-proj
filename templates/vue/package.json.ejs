{
  "name": "<%= ctx.projectName %>",
  "version": "1.0.0",
  "description": "A new Vue App - <%= ctx.projectName %>",
  "scripts": {
    "prepare": "lefthook install",
    "openapi-axios": "openapi-axios",
    <%_ if (codeLinter === 'biome') { _%>
    "lint": "biome check && vue-tsc --noEmit && stylelint '**/*.{css,scss}'",
    "lint:fix": "biome check --fix --unsafe && vue-tsc --noEmit && stylelint '**/*.{css,scss}' --fix",
    <%_ } else if (codeLinter === 'eslint') { _%>
    "lint": "eslint && vue-tsc --noEmit && stylelint '**/*.{css,scss}'",
    "lint:fix": "eslint --fix && vue-tsc --noEmit && stylelint '**/*.{css,scss}' --fix",
    <%_ } _%>
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production vue-tsc --build && vite build",
    "preview": "cross-env NODE_ENV=production vite preview",
    "release": "commit-and-tag-version"
  },
  "engines": {
    "node": ">=<%= nodeVersion %>"
  },
  "engineStrict": true,
  "dependencies": {
    "@unocss/reset": "^65.4.3",
    "axios": "^1.7.9",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-request": "^2.0.4",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    <%_ if (codeLinter === 'biome') { _%>
    "@biomejs/biome": "1.9.4",
    <%_ } else if (codeLinter === 'eslint') { _%>
    "@antfu/eslint-config": "^3.14.0",
    "@unocss/eslint-plugin": "^65.4.3",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    <%_ } _%>
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.5.0",
    "@types/node": "<%= nodeVersion %>",
    "commit-and-tag-version": "^12.5.0",
    "cross-env": "^7.0.3",
    "lefthook": "^1.10.3",
    "openapi-axios": "^0.31.0",
    "postcss": "^8.5.1",
    "sass-embedded": "^1.83.4",
    "stylelint": "^16.13.2",
    "stylelint-config-css-modules": "^4.4.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended": "^15.0.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard": "^37.0.0",
    "typescript": "^5.7.3",
    "unocss": "^65.4.0",
    "unplugin-vue-router": "^0.11.1",
    "vite": "^6.0.7",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-minify": "^2.1.0",
    "vite-svg-sprite": "^1.0.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vue-tsc": "^2.2.0"
  }
}
